# Branches enabled for deployment (space-separated).
# Only branches listed here will trigger a GitHub Pages deployment when pushed.
# Add a branch here when it has its stage secrets configured in GitHub.
DEPLOY_BRANCHES="main"

# Branch-to-stage mappings (optional overrides).
# By default each branch maps to its own stage (uppercase branch name).
# Use these to map multiple branches to the same stage, or to use a
# cleaner stage name than the branch name.
# Secrets must exist for the target stage: STAGE_<STAGE>_SUPABASE_URL etc.
# Examples:
#   BRANCH_HOTFIX_STAGE=MAIN
#   BRANCH_FEATURE_X_STAGE=TEST
